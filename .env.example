# Copy to .env for local dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_SESSION_TOKEN=

# Bedrock model IDs
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Optional: if you want to point local API at Qdrant Cloud instead of local container
# QDRANT_URL=https://<cluster-id>.<region>.qdrant.cloud
# QDRANT_API_KEY=<api-key>
